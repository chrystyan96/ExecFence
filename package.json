{
  "name": "execfence",
  "version": "5.0.0",
  "description": "Guard package-manager installs, dependency changes, CI, and agent-run commands before suspicious project code executes.",
  "license": "Apache-2.0",
  "author": "Chrystyan Byrnes",
  "type": "commonjs",
  "bin": {
    "execfence": "bin/execfence.js"
  },
  "files": [
    "bin/",
    "docs/",
    "examples/",
    "helper/",
    "lib/",
    "schema/",
    "skill/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "pretest": "npm run scan",
    "test": "node --test",
    "helper:test": "cd helper && go test ./...",
    "helper:build": "cd helper && go build -o ../.execfence/cache/execfence-helper-local.exe ./cmd/execfence-helper",
    "helper:smoke": "node scripts/helper-smoke.cjs",
    "scan": "node bin/execfence.js scan .",
    "coverage:execfence": "node bin/execfence.js coverage",
    "pr:check": "npm test && npm run scan",
    "check": "npm test && npm run scan && node bin/execfence.js ci",
    "release:weekly-check": "npm run check && npm run helper:smoke && node bin/execfence.js run -- npm test && node bin/execfence.js ci && node bin/execfence.js manifest && node bin/execfence.js pack-audit && npm pack --dry-run",
    "publish:dry": "node bin/execfence.js publish",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "security",
    "supply-chain",
    "malware",
    "guardrails",
    "codex",
    "claude",
    "gemini",
    "cursor",
    "agents",
    "npx",
    "tauri",
    "node",
    "go",
    "execfence"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chrystyan96/ExecFence.git"
  },
  "bugs": {
    "url": "https://github.com/chrystyan96/ExecFence/issues"
  },
  "homepage": "https://chrystyan96.github.io/ExecFence/"
}
